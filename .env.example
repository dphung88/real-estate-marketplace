# Copy this file to .env.local and fill in your values

# Stripe (required for Used Items checkout)
STRIPE_SECRET_KEY=paste_your_key_from_stripe_dashboard

# Supabase (required for Real Estate listings)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx

# Resend (required for Contact form)
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Optional: Site URL for Stripe redirects (Vercel sets VERCEL_URL automatically)
NEXT_PUBLIC_SITE_URL=https://edisonyang.xyz
